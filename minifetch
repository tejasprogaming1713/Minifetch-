#!/bin/bash

clear

CYAN="\e[36m"
GREEN="\e[32m"
YELLOW="\e[33m"
NC="\e[0m"

LOGO='
_____ ______   ___  ________   ___  ________ _______  _________  ________  ___  ___     
|\   _ \  _   \|\  \|\   ___  \|\  \|\  _____\\  ___ \|\___   ___\\   ____\|\  \|\  \    
\ \  \\\__\ \  \ \  \ \  \\ \  \ \  \ \  \__/\ \   __/\|___ \  \_\ \  \___|\ \  \\\  \   
 \ \  \\|__| \  \ \  \ \  \\ \  \ \  \ \   __\\ \  \_|/__  \ \  \ \ \  \    \ \   __  \  
  \ \  \    \ \  \ \  \ \  \\ \  \ \  \ \  \_| \ \  \_|\ \  \ \  \ \ \  \____\ \  \ \  \ 
   \ \__\    \ \__\ \__\ \__\\ \__\ \__\ \__\   \ \_______\  \ \__\ \ \_______\ \__\ \__\
    \|__|     \|__|\|__|\|__| \|__|\|__|\|__|    \|_______|   \|__|  \|_______|\|__|\|__|
'

HOST=$(hostname)
USER=$(whoami)
OS=$(grep PRETTY_NAME /etc/os-release | cut -d= -f2 | tr -d '"')
KERNEL=$(uname -r)
ARCH=$(uname -m)
UPTIME=$(uptime -p)

CPU=$(grep -m1 "model name" /proc/cpuinfo | cut -d: -f2 | sed 's/^ //')
CORES=$(nproc)

RAM_USED=$(free -h | awk '/Mem:/ {print $3}')
RAM_TOTAL=$(free -h | awk '/Mem:/ {print $2}')

DISK=$(df -h / | awk 'NR==2 {print $3 " / " $2}')

PUB_IP=$(curl -s ifconfig.me)
PRI_IP=$(hostname -I | awk '{print $1}')

echo -e "${CYAN}${LOGO}${NC}"
echo -e "${GREEN}${USER}@${HOST}${NC}"
echo -e "${YELLOW}────────────────────────────────────────${NC}"
echo -e "OS        : $OS"
echo -e "Kernel    : $KERNEL"
echo -e "Arch      : $ARCH"
echo -e "Uptime    : $UPTIME"
echo -e "CPU       : $CPU"
echo -e "Cores     : $CORES"
echo -e "RAM       : $RAM_USED / $RAM_TOTAL"
echo -e "Disk      : $DISK"
echo -e "PrivateIP : $PRI_IP"
echo -e "PublicIP  : $PUB_IP"
